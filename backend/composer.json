{
  "name": "sederg-pay-backend",
  "description": "SEDERG PAY - Yii2 Backend for Remesas Platform",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "yiisoft/yii2": "^2.0.46",
    "yiisoft/yii2-swiftmailer": "^2.1.0",
    "firebase/php-jwt": "^6.0",
    "nesbot/carbon": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "codeception/codeception": "^4.1"
  },
  "autoload": {
    "psr-4": {
      "app\\": "."
    }
  },
  "scripts": {
    "post-install-cmd": [
      "yii\\composer\\Installer::postInstall"
    ],
    "post-create-project-cmd": [
      "yii\\composer\\Installer::postCreateProject"
    ]
  },
  "extra": {
    "yii-install-writable": [
      "runtime",
      "web/assets"
    ],
    "yii-install-writable-dirs": [
      "runtime",
      "web/assets"
    ]
  }
}